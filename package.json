{
    "name": "tablerise-frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "dev:coverage": "cross-env CYPRESS_COVERAGE=true next dev -p 3000",
        "build:coverage": "cross-env CYPRESS_COVERAGE=true next build",
        "build": "next build",
        "start": "next start",
        "start:coverage": "cross-env CYPRESS_COVERAGE=true next start -p 3000",
        "lint": "next lint",
        "prettier": "npx prettier --check .",
        "prettier:fix": "npx prettier . --write",
        "test:cy": "node scripts/run-cypress.cjs open",
        "test:cy:run": "node scripts/run-cypress.cjs run",
        "test:cy:coverage": "npm run build:coverage && start-server-and-test \"npm run start:coverage\" http://127.0.0.1:3000 \"npm run test:cy:run\"",
        "coverage:report": "nyc report --reporter=text-summary --reporter=html --reporter=lcov",
        "coverage:check": "nyc check-coverage --lines 50 --functions 50 --branches 50 --statements 50",
        "coverage:cy": "npm run test:cy:coverage && npm run coverage:report && npm run coverage:check",
        "prepare": "husky install"
    },
    "dependencies": {
        "@3d-dice/dice-box": "1.1.4",
        "@3d-dice/dice-box-threejs": "0.0.12",
        "@hookform/resolvers": "3.9.1",
        "@tablerise/database-management": "7.2.15",
        "@tsparticles/engine": "3.9.1",
        "@tsparticles/react": "3.0.0",
        "@tsparticles/slim": "3.9.1",
        "axios": "1.7.4",
        "embla-carousel-react": "8.6.0",
        "framer-motion": "12.38.0",
        "next": "14.2.4",
        "react": "18",
        "react-dom": "18",
        "react-hook-form": "7.54.0",
        "react-image-crop": "^11.0.10",
        "rpg-dice-roller": "5.0.0",
        "sharp": "0.33.5",
        "socket.io-client": "4.8.3",
        "uuid": "11.1.0",
        "zod": "3.24.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@cypress/code-coverage": "^4.0.3",
        "@svgr/webpack": "8.1.0",
        "@types/node": "20",
        "@types/react": "18",
        "@types/react-dom": "18",
        "babel-loader": "^10.1.1",
        "babel-plugin-istanbul": "^8.0.0",
        "chalk": "4.1.2",
        "cross-env": "^10.1.0",
        "cypress": "^15.16.0",
        "eslint": "8",
        "eslint-config-next": "14.2.4",
        "eslint-config-prettier": "9.1.0",
        "eslint-plugin-prettier": "5.2.1",
        "husky": "8.0.3",
        "nyc": "^18.0.0",
        "postcss": "8",
        "prettier": "3.0.0",
        "start-server-and-test": "^3.0.5",
        "tailwindcss": "3.4.1",
        "typescript": "6.0.2"
    }
}
